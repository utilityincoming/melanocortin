---
import BaseLayout from './BaseLayout.astro';
import Byline from '../components/Byline.astro';

interface Props {
  title: string;
  description?: string;
  kicker?: string;
  status?: string;
  author?: string;
  updated?: string;
  reviewed?: boolean;
}

const { title, description, kicker, status, author, updated, reviewed } = Astro.props;
---

<BaseLayout title={`${title} — melanocortin.com`} description={description}>
  <article class="mx-auto max-w-3xl px-6 py-16">
    <header class="border-b border-[var(--border)] pb-8">
      {
        kicker && (
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--accent)]">
            {kicker}
          </p>
        )
      }
      <h1 class="mt-3 font-serif text-4xl leading-tight font-semibold tracking-tight">
        {title}
      </h1>
      {
        description && (
          <p class="mt-4 text-lg leading-relaxed text-[var(--text-muted)]">
            {description}
          </p>
        )
      }
      {updated && <Byline author={author} updated={updated} reviewed={reviewed} />}
      {
        status && (
          <p class="mt-5 inline-flex items-center gap-2 rounded-full border border-[var(--border)] px-3 py-1 text-xs text-[var(--text-muted)]">
            <span class="h-1.5 w-1.5 rounded-full bg-[var(--accent)]"></span>
            {status}
          </p>
        )
      }
    </header>
    <div
      class="mt-8 leading-relaxed [&_h2]:mt-10 [&_h2]:font-serif [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:tracking-tight [&_li]:mt-1.5 [&_li_a]:text-[var(--accent)] [&_li_a]:underline [&_li_a]:decoration-dotted [&_p]:mt-4 [&_p_a]:text-[var(--accent)] [&_p_a]:underline [&_p_a]:decoration-dotted [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-5"
    >
      <slot />
    </div>
  </article>
</BaseLayout>
