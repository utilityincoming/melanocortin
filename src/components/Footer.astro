---
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-[var(--border)]">
  <div class="mx-auto max-w-5xl px-6 py-10 text-sm text-[var(--text-muted)]">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
      <div class="max-w-sm">
        <p class="font-display text-base text-[var(--text)]">melanocortin.com</p>
        <p class="mt-2 leading-relaxed">
          An open, citation-first reference on the melanocortin system — POMC,
          the MC1R–MC5R receptors, and the therapeutics that target them.
        </p>
      </div>
      <nav class="flex flex-col gap-2" aria-label="Footer">
        <a href="/system" class="no-underline hover:text-[var(--accent)]">The system</a>
        <a href="/receptors" class="no-underline hover:text-[var(--accent)]">Receptors</a>
        <a href="/therapeutics" class="no-underline hover:text-[var(--accent)]">Therapeutics</a>
        <a href="/about" class="no-underline hover:text-[var(--accent)]">Editorial standards</a>
      </nav>
    </div>
    <div class="mt-8 border-t border-[var(--border)] pt-6 text-xs leading-relaxed">
      <p>
        Educational resource only — not medical advice, diagnosis, or treatment.
        Always consult a qualified clinician.
      </p>
      <p class="mt-2">
        © {year} melanocortin.com · Content licensed
        <a href="https://creativecommons.org/licenses/by/4.0/" class="underline decoration-dotted hover:text-[var(--accent)]">CC BY 4.0</a>
      </p>
    </div>
  </div>
</footer>
