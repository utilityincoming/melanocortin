---
const primary = [
  { href: '/system', label: 'The system' },
  { href: '/receptors', label: 'Receptors' },
  { href: '/therapeutics', label: 'Therapeutics' },
];
const tools = [
  { href: '/explorer', label: 'Receptor–ligand explorer', note: 'Which peptide hits which receptor' },
  { href: '/dose-curve', label: 'Dose & side-effect model', note: 'Why the peak, not the dose, drives nausea' },
  { href: '/pipeline', label: 'Therapeutics pipeline', note: 'A dated snapshot of drugs in development' },
];
const glossary = { href: '/glossary', label: 'Glossary' };

const path = Astro.url.pathname;
const isActive = (href: string) => path.startsWith(href);
const toolsActive = tools.some((t) => isActive(t.href));
---

<header class="relative border-b border-[var(--border)]">
  <nav
    class="mx-auto flex max-w-5xl items-center justify-between gap-6 px-6 py-4"
    aria-label="Primary"
  >
    <a href="/" class="group flex items-center gap-2.5 font-serif text-lg font-semibold tracking-tight no-underline">
      <span
        class="inline-block h-5 w-5 rounded-full"
        style="background: radial-gradient(circle at 30% 30%, var(--color-pigment-300), var(--color-pigment-700));"
        aria-hidden="true"></span>
      melanocortin
    </a>

    <!-- Desktop links -->
    <ul class="hidden items-center gap-6 text-sm sm:flex">
      {
        primary.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                'no-underline transition-colors hover:text-[var(--accent)]',
                isActive(l.href)
                  ? 'text-[var(--accent)] font-medium'
                  : 'text-[var(--text-muted)]',
              ]}
            >
              {l.label}
            </a>
          </li>
        ))
      }

      <!-- Tools disclosure (no-JS <details> dropdown) -->
      <li class="relative">
        <details class="group/tools">
          <summary
            class:list={[
              'flex cursor-pointer list-none items-center gap-1 no-underline transition-colors hover:text-[var(--accent)] [&::-webkit-details-marker]:hidden',
              toolsActive ? 'text-[var(--accent)] font-medium' : 'text-[var(--text-muted)]',
            ]}
          >
            Tools
            <svg
              class="h-3.5 w-3.5 transition-transform group-open/tools:rotate-180"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
            >
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </summary>
          <div
            class="absolute right-0 top-full z-50 mt-3 w-72 rounded-lg border border-[var(--border)] bg-[var(--bg-elevated)] p-2 shadow-sm"
          >
            <ul class="flex flex-col">
              {
                tools.map((t) => (
                  <li>
                    <a
                      href={t.href}
                      class:list={[
                        'flex flex-col gap-0.5 rounded-md px-3 py-2.5 no-underline transition-colors hover:bg-[var(--accent-soft)]',
                        isActive(t.href) ? 'bg-[var(--accent-soft)]' : '',
                      ]}
                    >
                      <span
                        class:list={[
                          'text-sm font-medium',
                          isActive(t.href) ? 'text-[var(--accent)]' : 'text-[var(--text)]',
                        ]}
                      >
                        {t.label}
                      </span>
                      <span class="text-xs leading-snug text-[var(--text-muted)]">{t.note}</span>
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </details>
      </li>

      <li>
        <a
          href={glossary.href}
          class:list={[
            'no-underline transition-colors hover:text-[var(--accent)]',
            isActive(glossary.href)
              ? 'text-[var(--accent)] font-medium'
              : 'text-[var(--text-muted)]',
          ]}
        >
          {glossary.label}
        </a>
      </li>
    </ul>

    <!-- Mobile menu (no-JS <details> disclosure) -->
    <details class="group sm:hidden">
      <summary
        class="flex cursor-pointer list-none items-center rounded-md p-1 text-[var(--text)] [&::-webkit-details-marker]:hidden"
        aria-label="Menu"
      >
        <svg class="h-6 w-6 group-open:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="4" y1="7" x2="20" y2="7" /><line x1="4" y1="12" x2="20" y2="12" /><line x1="4" y1="17" x2="20" y2="17" />
        </svg>
        <svg class="hidden h-6 w-6 group-open:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="6" y1="6" x2="18" y2="18" /><line x1="18" y1="6" x2="6" y2="18" />
        </svg>
      </summary>
      <div class="absolute inset-x-0 top-full z-50 border-b border-[var(--border)] bg-[var(--bg)] shadow-sm">
        <ul class="mx-auto flex max-w-5xl flex-col px-6 py-2 text-sm">
          {
            primary.map((l) => (
              <li>
                <a
                  href={l.href}
                  class:list={[
                    'block border-b border-[var(--border)] py-3 no-underline transition-colors hover:text-[var(--accent)]',
                    isActive(l.href)
                      ? 'font-medium text-[var(--accent)]'
                      : 'text-[var(--text)]',
                  ]}
                >
                  {l.label}
                </a>
              </li>
            ))
          }

          <li class="border-b border-[var(--border)] py-3">
            <span class="font-mono text-xs uppercase tracking-[0.15em] text-[var(--text-muted)]">
              Tools
            </span>
            <ul class="mt-2 flex flex-col gap-1">
              {
                tools.map((t) => (
                  <li>
                    <a
                      href={t.href}
                      class:list={[
                        'block py-1.5 no-underline transition-colors hover:text-[var(--accent)]',
                        isActive(t.href) ? 'font-medium text-[var(--accent)]' : 'text-[var(--text)]',
                      ]}
                    >
                      {t.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </li>

          <li>
            <a
              href={glossary.href}
              class:list={[
                'block py-3 no-underline transition-colors hover:text-[var(--accent)]',
                isActive(glossary.href)
                  ? 'font-medium text-[var(--accent)]'
                  : 'text-[var(--text)]',
              ]}
            >
              {glossary.label}
            </a>
          </li>
        </ul>
      </div>
    </details>
  </nav>
</header>
