---
// "The appetite circuit" — original animated explainer for the metabolic axis,
// the twin of PigmentSwitch. Big idea in one loop: leptin from fat tells the
// arcuate nucleus how full the body is; POMC neurons fire α-MSH (satiety) while
// AgRP neurons fire the opposing hunger signal, and MC4R is the rheostat that
// integrates the tug-of-war. Break any upstream part (LEPR, POMC, PCSK1, MC4R)
// and the dial sticks on "hunger" — setmelanotide turns it back toward "full".
// Self-contained; themed via CSS vars; honours prefers-reduced-motion.
interface Props {
  caption?: boolean;
}
const { caption = true } = Astro.props;
---

<figure class="appetite-circuit not-prose my-8">
  <svg
    viewBox="0 0 820 460"
    role="img"
    aria-labelledby="ac-title ac-desc"
    xmlns="http://www.w3.org/2000/svg"
  >
    <title id="ac-title">The leptin–melanocortin appetite circuit</title>
    <desc id="ac-desc"
      >Leptin from fat signals the hypothalamus, where POMC neurons release α-MSH
      (satiety) and AgRP neurons release the opposing hunger signal; MC4R is the
      rheostat that integrates them. Loss of LEPR, POMC, PCSK1 or MC4R sticks the
      dial on hunger, and setmelanotide turns it back toward full.</desc
    >

    <!-- fat / adipose -->
    <g class="adipose">
      <ellipse cx="92" cy="330" rx="50" ry="36" />
      <circle cx="80" cy="322" r="7" class="lipid" />
      <circle cx="104" cy="336" r="9" class="lipid" />
      <circle cx="88" cy="346" r="5" class="lipid" />
    </g>
    <text x="92" y="384" text-anchor="middle" class="cap">adipose (fat)</text>

    <!-- travelling leptin token -->
    <g class="leptin-token">
      <rect x="70" y="292" width="66" height="26" rx="13" />
      <text x="103" y="309" text-anchor="middle" class="tok-t">leptin</text>
    </g>

    <!-- arcuate nucleus -->
    <rect x="238" y="118" width="212" height="212" rx="18" class="nucleus-box" />
    <text x="344" y="110" text-anchor="middle" class="head">arcuate nucleus</text>

    <!-- leptin → POMC (+) and ⊣ AgRP (−) -->
    <circle cx="262" cy="176" r="10" class="plus-glyph" />
    <text x="262" y="180" text-anchor="middle" class="glyph-t">+</text>
    <circle cx="262" cy="268" r="10" class="minus-glyph" />
    <text x="262" y="272" text-anchor="middle" class="glyph-t">−</text>

    <!-- POMC neuron -->
    <circle cx="344" cy="176" r="40" class="pomc-glow" />
    <rect x="298" y="156" width="96" height="42" rx="12" class="pomc-node" />
    <text x="346" y="173" text-anchor="middle" class="node-t">POMC</text>
    <text x="346" y="189" text-anchor="middle" class="node-sub">→ α-MSH</text>

    <!-- AgRP neuron -->
    <circle cx="344" cy="268" r="40" class="agrp-glow" />
    <rect x="298" y="248" width="96" height="42" rx="12" class="agrp-node" />
    <text x="346" y="265" text-anchor="middle" class="node-t">AgRP / NPY</text>
    <text x="346" y="281" text-anchor="middle" class="node-sub">the hunger brake-release</text>

    <!-- wires to the rheostat -->
    <path d="M394 176 C470 176 500 232 556 250" class="wire sat-wire" />
    <path d="M394 268 C470 268 505 288 556 292" class="wire hunger-wire" />
    <circle r="6" class="pulse sat-pulse" cx="394" cy="176" />
    <circle r="6" class="pulse hunger-pulse" cx="394" cy="268" />

    <!-- MC4R rheostat -->
    <g class="gauge">
      <path d="M550 275 A80 80 0 0 1 710 275" class="gauge-arc" />
      <line x1="550" y1="275" x2="710" y2="275" class="gauge-base" />
      <!-- ticks -->
      <line x1="560" y1="248" x2="571" y2="256" class="tick" />
      <line x1="630" y1="197" x2="630" y2="210" class="tick" />
      <line x1="700" y1="248" x2="689" y2="256" class="tick" />
      <!-- needle -->
      <line x1="630" y1="275" x2="630" y2="207" class="needle" />
      <circle cx="630" cy="275" r="7" class="needle-hub" />
    </g>
    <text x="556" y="298" text-anchor="end" class="zone-hunger">HUNGER</text>
    <text x="704" y="298" text-anchor="start" class="zone-full">FULL</text>
    <text x="630" y="322" text-anchor="middle" class="cap-strong">MC4R rheostat</text>
    <text x="630" y="338" text-anchor="middle" class="cap">integrates both signals</text>

    <!-- setmelanotide: the therapeutic that turns the dial back -->
    <g class="drug-token">
      <rect x="560" y="372" width="140" height="30" rx="15" />
      <text x="630" y="392" text-anchor="middle" class="drug-t">setmelanotide →</text>
    </g>
    <path d="M630 372 L630 340" class="wire drug-wire" />
    <circle r="6" class="pulse drug-pulse" cx="630" cy="360" />

    <!-- where it breaks -->
    <text x="30" y="436" class="cap">
      Break any upstream part — LEPR, POMC, PCSK1, or MC4R itself — and the dial
      sticks on hunger. Setmelanotide re-agonises MC4R downstream of the break.
    </text>
  </svg>

  {
    caption && (
      <figcaption>
        A tug-of-war, not a switch. <strong>Leptin</strong> from fat tips the
        balance: it drives <strong>POMC → α-MSH</strong> (satiety) and quiets{' '}
        <strong>AgRP</strong> (hunger), and <strong>MC4R</strong> is the dial that
        reads the result. The monogenic-obesity genes are the parts of this circuit
        that can fail — and <strong>setmelanotide</strong> turns the dial back
        toward full from downstream.
      </figcaption>
    )
  }
</figure>

<style>
  .appetite-circuit {
    --sat: var(--accent);
    --hunger: var(--color-ink-400);
    --leptin: #2f9e8f;
    --drug: #5a86d8;
    max-width: 46rem;
    margin-inline: auto;
  }
  @media (prefers-color-scheme: dark) {
    .appetite-circuit {
      --hunger: var(--color-ink-300);
      --leptin: #46c2b0;
      --drug: #86a8f2;
    }
  }

  .appetite-circuit svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    background: var(--bg-elevated);
    padding: 0.5rem;
  }

  /* text */
  .head {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 14px;
    font-weight: 600;
    fill: var(--text);
  }
  .cap { font-size: 11.5px; fill: var(--text-muted); }
  .cap-strong { font-size: 13px; font-weight: 600; fill: var(--text); }
  .tok-t { font-size: 12px; font-weight: 600; fill: #fff; }
  .drug-t { font-size: 12.5px; font-weight: 600; fill: #fff; }
  .node-t { font-size: 12.5px; font-weight: 600; fill: var(--text); }
  .node-sub { font-size: 10px; fill: var(--text-muted); }
  .glyph-t { font-size: 13px; font-weight: 700; fill: #fff; }
  .zone-hunger { font-size: 11px; font-weight: 600; fill: var(--hunger); letter-spacing: 0.05em; }
  .zone-full { font-size: 11px; font-weight: 600; fill: var(--sat); letter-spacing: 0.05em; }

  /* structure */
  .adipose ellipse { fill: var(--color-pigment-200); stroke: var(--border); stroke-width: 1; }
  .lipid { fill: var(--color-pigment-400); opacity: 0.55; }
  .nucleus-box { fill: none; stroke: var(--border); stroke-width: 1.5; stroke-dasharray: 4 4; }
  .pomc-node { fill: var(--accent-soft); stroke: var(--sat); stroke-width: 1.5; }
  .agrp-node { fill: var(--bg); stroke: var(--hunger); stroke-width: 1.5; }
  .plus-glyph { fill: var(--sat); }
  .minus-glyph { fill: var(--hunger); }
  .wire { fill: none; stroke: var(--border); stroke-width: 2; }
  .sat-wire { stroke: var(--sat); opacity: 0.4; }
  .hunger-wire { stroke: var(--hunger); opacity: 0.4; }
  .drug-wire { stroke: var(--drug); opacity: 0.4; }
  .gauge-arc { fill: none; stroke: var(--border); stroke-width: 6; stroke-linecap: round; }
  .gauge-base { stroke: var(--border); stroke-width: 1; opacity: 0.5; }
  .tick { stroke: var(--text-muted); stroke-width: 2; stroke-linecap: round; }
  .needle-hub { fill: var(--text); }
  .leptin-token rect { fill: var(--leptin); }
  .drug-token rect { fill: var(--drug); }
  .sat-pulse { fill: var(--sat); }
  .hunger-pulse { fill: var(--hunger); }
  .drug-pulse { fill: var(--drug); }

  /* animated needle */
  .needle {
    stroke: var(--accent-strong);
    stroke-width: 4;
    stroke-linecap: round;
    transform-box: view-box;
    transform-origin: 630px 275px;
    transform: rotate(-50deg);
    animation: needleSwing 8s ease-in-out infinite;
  }

  .pomc-glow, .agrp-glow { opacity: 0; transform-box: fill-box; transform-origin: center; }
  .pomc-glow { fill: var(--sat); animation: pomcGlow 8s linear infinite; }
  .agrp-glow { fill: var(--hunger); animation: agrpGlow 8s linear infinite; }

  .pulse { opacity: 0; transform-box: view-box; }
  .leptin-token { opacity: 0; transform-box: view-box; animation: leptinTravel 8s linear infinite; }
  .sat-pulse { animation: satPulse 8s linear infinite; }
  .hunger-pulse { animation: hungerPulse 8s linear infinite; }
  .drug-token { opacity: 0; transform-box: view-box; animation: drugToken 8s linear infinite; }
  .drug-pulse { animation: drugPulse 8s linear infinite; }

  @keyframes needleSwing {
    0%, 12% { transform: rotate(-50deg); }
    28% { transform: rotate(46deg); }
    40% { transform: rotate(-6deg); }
    55% { transform: rotate(40deg); }
    70%, 88% { transform: rotate(54deg); }
    100% { transform: rotate(-50deg); }
  }
  @keyframes leptinTravel {
    0% { opacity: 0; transform: translate(0, 0); }
    4% { opacity: 1; }
    15% { opacity: 1; transform: translate(168px, -128px); }
    20%, 100% { opacity: 0; transform: translate(168px, -128px); }
  }
  @keyframes satPulse {
    0%, 15% { opacity: 0; transform: translate(0, 0); }
    17% { opacity: 1; }
    28% { opacity: 1; transform: translate(168px, 74px); }
    31%, 100% { opacity: 0; transform: translate(168px, 74px); }
  }
  @keyframes hungerPulse {
    0%, 30% { opacity: 0; transform: translate(0, 0); }
    32% { opacity: 1; }
    42% { opacity: 1; transform: translate(168px, 24px); }
    45%, 100% { opacity: 0; transform: translate(168px, 24px); }
  }
  @keyframes drugToken {
    0%, 56% { opacity: 0; }
    60%, 86% { opacity: 1; }
    92%, 100% { opacity: 0; }
  }
  @keyframes drugPulse {
    0%, 58% { opacity: 0; transform: translate(0, 6px); }
    62% { opacity: 1; transform: translate(0, 0); }
    72% { opacity: 1; transform: translate(0, -30px); }
    76%, 100% { opacity: 0; transform: translate(0, -30px); }
  }
  @keyframes pomcGlow {
    0%, 14% { opacity: 0; }
    18%, 30% { opacity: 0.8; }
    40%, 100% { opacity: 0; }
  }
  @keyframes agrpGlow {
    0%, 30% { opacity: 0; }
    34%, 44% { opacity: 0.7; }
    52%, 100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .needle, .pomc-glow, .agrp-glow, .leptin-token, .drug-token, .pulse { animation: none; }
    .needle { transform: rotate(48deg); }
    .pomc-glow { opacity: 0.8; }
    .agrp-glow, .leptin-token, .drug-token, .pulse { opacity: 0; }
  }

  figcaption {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-muted);
    text-align: center;
    max-width: 42rem;
    margin-inline: auto;
  }
  figcaption strong { color: var(--text); font-weight: 600; }
</style>
