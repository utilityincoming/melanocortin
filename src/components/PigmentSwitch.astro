---
// "The pigment switch" — an original, self-contained animated explainer.
// Big idea in one loop: α-MSH activates MC1R and flips melanocytes from
// red/yellow pheomelanin to brown/black eumelanin. The SAME signal darkens a
// lizard (the classic melanophore demonstration) and tans human skin — where
// eumelanin then absorbs UV before it reaches DNA. No external assets; themes
// via CSS vars; honours prefers-reduced-motion with an informative still frame.
interface Props {
  caption?: boolean;
}
const { caption = true } = Astro.props;
---

<figure class="pigment-switch not-prose my-8">
  <svg
    viewBox="0 0 820 500"
    role="img"
    aria-labelledby="ps-title ps-desc"
    xmlns="http://www.w3.org/2000/svg"
  >
    <title id="ps-title">The melanocortin pigment switch</title>
    <desc id="ps-desc"
      >α-MSH activates the MC1R receptor, switching melanocytes from pale
      UV-vulnerable pheomelanin to dark protective eumelanin — darkening a lizard
      and tanning human skin so eumelanin absorbs UV before it damages DNA.</desc
    >

    <!-- ============ MECHANISM BAND ============ -->
    <g class="lbl">
      <!-- α-MSH token -->
      <rect x="30" y="46" width="108" height="46" rx="11" class="token" />
      <text x="84" y="74" text-anchor="middle" class="token-t">α-MSH</text>

      <!-- wire + travelling pulse -->
      <line x1="138" y1="69" x2="250" y2="69" class="wire" />
      <circle cx="138" cy="69" r="6" class="pulse" />

      <!-- MC1R receptor -->
      <circle cx="278" cy="69" r="24" class="mc1r-glow" />
      <rect x="264" y="49" width="28" height="40" rx="9" class="receptor" />
      <text x="278" y="112" text-anchor="middle" class="cap">MC1R</text>

      <!-- arrow to cell -->
      <path d="M306 69 H396" class="wire" marker-end="url(#ah)" />

      <!-- melanocyte (dendritic cell that fills with pigment) -->
      <g class="melanocyte">
        <path
          class="cell"
          d="M470 40 l14 -14 l-4 20 l22 -8 l-12 18 l20 6 l-20 8 l12 16 l-20 -8 l3 20 l-14 -14
             l-14 14 l3 -20 l-20 8 l12 -16 l-20 -8 l20 -6 l-12 -18 l22 8 l-4 -20 z"
        />
        <circle cx="470" cy="69" r="9" class="nucleus" />
      </g>
      <text x="470" y="126" text-anchor="middle" class="cap">melanocyte</text>

      <!-- arrow to output -->
      <path d="M516 69 H600" class="wire" marker-end="url(#ah)" />
      <circle cx="626" cy="69" r="14" class="swatch" />
      <text x="648" y="65" class="cap-strong">eumelanin</text>
      <text x="648" y="82" class="cap">the protective pigment</text>
    </g>

    <line x1="24" y1="150" x2="796" y2="150" class="divider" />

    <!-- ============ RESULT BAND ============ -->
    <text x="210" y="182" text-anchor="middle" class="head">The demonstration</text>
    <text x="602" y="182" text-anchor="middle" class="head">The translation</text>

    <!-- LEFT: lizard darkens -->
    <g class="lizard">
      <!-- tail -->
      <path d="M168 300 Q116 288 86 306 Q78 311 86 315 Q118 300 172 305 Z" />
      <!-- legs -->
      <line x1="238" y1="286" x2="256" y2="262" class="limb" />
      <line x1="238" y1="314" x2="256" y2="338" class="limb" />
      <line x1="186" y1="286" x2="168" y2="260" class="limb" />
      <line x1="186" y1="314" x2="168" y2="340" class="limb" />
      <!-- body + head -->
      <ellipse cx="210" cy="300" rx="47" ry="23" />
      <ellipse cx="272" cy="300" rx="19" ry="14" />
      <circle cx="280" cy="294" r="2.6" class="eye" />
    </g>
    <text x="210" y="372" text-anchor="middle" class="cap">
      melanophores disperse pigment — dark in minutes
    </text>

    <!-- RIGHT: UV sun -->
    <g class="sun">
      <circle cx="505" cy="212" r="13" />
      <g class="rays-static">
        <line x1="505" y1="190" x2="505" y2="197" />
        <line x1="483" y1="212" x2="490" y2="212" />
        <line x1="489" y1="196" x2="494" y2="201" />
      </g>
    </g>
    <text x="505" y="188" text-anchor="middle" class="cap">UV</text>

    <!-- exposed state: UV passes through pale skin to DNA -->
    <g class="exposed">
      <line x1="516" y1="222" x2="572" y2="382" class="uv-ray" />
      <line x1="524" y1="221" x2="608" y2="382" class="uv-ray" />
      <line x1="532" y1="220" x2="646" y2="372" class="uv-ray" />
      <g class="spark" transform="translate(600 384)">
        <path d="M0 -13 L3 -3 L13 0 L3 3 L0 13 L-3 3 L-13 0 L-3 -3 Z" />
      </g>
    </g>

    <!-- protected state: UV stops at tanned surface + shield -->
    <g class="protected">
      <line x1="516" y1="222" x2="560" y2="252" class="uv-ray" />
      <line x1="524" y1="221" x2="600" y2="250" class="uv-ray" />
      <line x1="532" y1="220" x2="640" y2="252" class="uv-ray" />
      <path d="M502 250 Q602 224 702 250" class="shield" />
    </g>

    <!-- human skin patch -->
    <rect x="504" y="250" width="196" height="80" rx="16" class="skin" />
    <g class="pores">
      <circle cx="540" cy="278" r="1.8" /><circle cx="580" cy="298" r="1.8" />
      <circle cx="628" cy="272" r="1.8" /><circle cx="664" cy="300" r="1.8" />
      <circle cx="600" cy="266" r="1.8" />
    </g>

    <!-- DNA helix under the skin -->
    <g class="dna" transform="translate(600 384)">
      <path d="M-10 -18 C10 -8 10 8 -10 18" class="strand" />
      <path d="M10 -18 C-10 -8 -10 8 10 18" class="strand" />
      <line x1="-8" y1="-12" x2="8" y2="-12" class="rung" />
      <line x1="-9" y1="0" x2="9" y2="0" class="rung" />
      <line x1="-8" y1="12" x2="8" y2="12" class="rung" />
    </g>
    <text x="602" y="416" text-anchor="middle" class="cap">
      eumelanin absorbs UV — shields DNA
    </text>

    <!-- ============ LEGEND ============ -->
    <g class="legend" transform="translate(0 452)">
      <circle cx="212" cy="18" r="9" class="chip-pheo" />
      <text x="228" y="22" class="cap">pheomelanin · fair, UV-vulnerable</text>
      <circle cx="512" cy="18" r="9" class="chip-eumel" />
      <text x="528" y="22" class="cap">eumelanin · tanned, UV-protective</text>
    </g>

    <defs>
      <marker id="ah" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0 0 L6 3 L0 6 Z" class="arrowhead" />
      </marker>
    </defs>
  </svg>

  {
    caption && (
      <figcaption>
        One molecule, one switch. α-MSH activates <strong>MC1R</strong>, flipping
        melanocytes from pale pheomelanin to dark <strong>eumelanin</strong> — the
        signal that darkens a lizard in minutes is the same one that tans human
        skin, where eumelanin then absorbs UV before it reaches DNA.
      </figcaption>
    )
  }
</figure>

<style>
  .pigment-switch {
    --pheo: var(--color-pigment-200);
    --eumel: var(--color-pigment-900);
    --uv: #7b6cd6;
    --spark: var(--color-pigment-400);
    max-width: 44rem;
    margin-inline: auto;
  }
  @media (prefers-color-scheme: dark) {
    .pigment-switch {
      --pheo: var(--color-pigment-300);
      --eumel: var(--color-pigment-700);
      --uv: #9b8cf0;
    }
  }

  .pigment-switch svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    background: var(--bg-elevated);
    padding: 0.5rem;
  }

  /* text */
  .head {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 15px;
    font-weight: 600;
    fill: var(--text);
  }
  .cap {
    font-size: 11.5px;
    fill: var(--text-muted);
  }
  .cap-strong {
    font-size: 13px;
    font-weight: 600;
    fill: var(--text);
  }
  .token-t {
    font-size: 15px;
    font-weight: 600;
    fill: var(--accent-strong);
  }

  /* structure */
  .token {
    fill: var(--accent-soft);
    stroke: var(--accent);
    stroke-width: 1.5;
  }
  .wire {
    stroke: var(--border);
    stroke-width: 2;
    fill: none;
  }
  .arrowhead {
    fill: var(--text-muted);
  }
  .divider {
    stroke: var(--border);
    stroke-width: 1;
  }
  .receptor {
    fill: var(--accent);
  }
  .nucleus {
    fill: var(--bg-elevated);
    opacity: 0.55;
  }
  .swatch {
    fill: var(--eumel);
    stroke: var(--border);
    stroke-width: 1;
  }
  .eye {
    fill: var(--bg-elevated);
  }
  .sun circle {
    fill: var(--uv);
  }
  .rays-static line {
    stroke: var(--uv);
    stroke-width: 2;
    stroke-linecap: round;
  }
  .uv-ray {
    stroke: var(--uv);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-dasharray: 3 4;
  }
  .shield {
    fill: none;
    stroke: var(--accent);
    stroke-width: 3;
    stroke-linecap: round;
    opacity: 0.9;
  }
  .spark path {
    fill: var(--spark);
  }
  .pores circle {
    fill: var(--eumel);
    opacity: 0.28;
  }
  .dna .strand {
    fill: none;
    stroke: var(--text-muted);
    stroke-width: 2.2;
  }
  .dna .rung {
    stroke: var(--text-muted);
    stroke-width: 1.6;
  }
  .chip-pheo {
    fill: var(--pheo);
    stroke: var(--border);
    stroke-width: 1;
  }
  .chip-eumel {
    fill: var(--eumel);
    stroke: var(--border);
    stroke-width: 1;
  }

  /* animated subjects: fill (+stroke) inherited by children */
  .lizard {
    fill: var(--pheo);
    stroke: var(--pheo);
    animation: darken 7s linear infinite;
  }
  .lizard .limb {
    stroke-width: 7;
    stroke-linecap: round;
  }
  .cell {
    fill: var(--pheo);
    animation: darkenFill 7s linear infinite;
  }
  .skin {
    fill: var(--pheo);
    stroke: var(--border);
    stroke-width: 1.5;
    animation: darkenFill 7s linear infinite;
  }

  .pulse {
    fill: var(--accent);
    opacity: 0;
    transform-box: fill-box;
    animation: pulseTravel 7s linear infinite;
  }
  .mc1r-glow {
    fill: var(--accent);
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    animation: glowPulse 7s linear infinite;
  }
  .exposed {
    opacity: 1;
    animation: exposeFade 7s linear infinite;
  }
  .protected {
    opacity: 0;
    animation: protectFade 7s linear infinite;
  }
  .spark {
    transform-box: fill-box;
    transform-origin: center;
    animation: sparkTwinkle 1.1s ease-in-out infinite;
  }

  @keyframes darken {
    0%, 22% { fill: var(--pheo); stroke: var(--pheo); }
    45%, 76% { fill: var(--eumel); stroke: var(--eumel); }
    96%, 100% { fill: var(--pheo); stroke: var(--pheo); }
  }
  @keyframes darkenFill {
    0%, 22% { fill: var(--pheo); }
    45%, 76% { fill: var(--eumel); }
    96%, 100% { fill: var(--pheo); }
  }
  @keyframes exposeFade {
    0%, 20% { opacity: 1; }
    40%, 78% { opacity: 0; }
    95%, 100% { opacity: 1; }
  }
  @keyframes protectFade {
    0%, 22% { opacity: 0; }
    45%, 74% { opacity: 1; }
    96%, 100% { opacity: 0; }
  }
  @keyframes pulseTravel {
    0%, 6% { opacity: 0; transform: translateX(0); }
    9% { opacity: 1; }
    20% { opacity: 1; transform: translateX(104px); }
    24%, 100% { opacity: 0; transform: translateX(104px); }
  }
  @keyframes glowPulse {
    0%, 20% { opacity: 0; }
    26%, 44% { opacity: 0.8; }
    60%, 100% { opacity: 0; }
  }
  @keyframes sparkTwinkle {
    0%, 100% { transform: scale(0.82); opacity: 0.7; }
    50% { transform: scale(1.08); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lizard, .cell, .skin, .pulse, .mc1r-glow, .exposed, .protected, .spark {
      animation: none;
    }
    .lizard { fill: var(--eumel); stroke: var(--eumel); }
    .cell, .skin { fill: var(--eumel); }
    .exposed { opacity: 0; }
    .protected { opacity: 1; }
    .pulse { opacity: 0; }
    .mc1r-glow { opacity: 0.8; }
  }

  figcaption {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-muted);
    text-align: center;
    max-width: 40rem;
    margin-inline: auto;
  }
  figcaption strong {
    color: var(--text);
    font-weight: 600;
  }
</style>
