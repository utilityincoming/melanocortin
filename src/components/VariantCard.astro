---
// One gene/variant row from src/data/variants.ts, rendered as a self-contained
// card. Citations are shown inline (author + year) rather than as prose-style
// footnotes, since a variant catalogue cites per-row; the page also carries a
// full bibliography at its foot.
import { EVIDENCE_LABEL, type Variant, type Evidence } from '../data/variants';

interface Props {
  variant: Variant;
}
const { variant: v } = Astro.props;

// Evidence badge. Colour-forward but never colour-only — the word carries the
// meaning. Strength reads from filled → outline → dashed on the warm palette.
const evidenceClass: Record<Evidence, string> = {
  established: 'border-[var(--accent)] bg-[var(--accent-soft)] text-[var(--accent-strong)]',
  strong: 'border-[var(--accent)] text-[var(--accent)]',
  emerging: 'border-[var(--border)] text-[var(--text-muted)]',
  contested: 'border-[var(--border)] border-dashed text-[var(--text-muted)]',
};

const receptorSlug = v.receptor ? v.receptor.toLowerCase() : null;

// Human-readable chips. `both`-axis rows advertise their pleiotropy explicitly
// so the same card appearing under two sections reads as intended, not doubled.
const tags = [
  v.axis === 'both' ? 'Both axes' : null,
  v.consequence.replace(/-/g, ' '),
  v.inheritance.replace(/-/g, ' '),
].filter((t): t is string => Boolean(t));
---

<article class="rounded-lg border border-[var(--border)] bg-[var(--bg-elevated)] p-5">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <span class="font-mono text-base font-semibold tracking-tight">{v.gene}</span>
      <span class="ml-2 text-sm text-[var(--text-muted)]">{v.variant}</span>
    </div>
    <span
      class:list={[
        'shrink-0 rounded-full border px-2 py-0.5 text-[0.6rem] font-medium uppercase tracking-wide',
        evidenceClass[v.evidence],
      ]}
      title="Strength of published evidence"
    >
      {EVIDENCE_LABEL[v.evidence]}
    </span>
  </div>

  <div class="mt-2.5 flex flex-wrap gap-1.5">
    {
      tags.map((t) => (
        <span class="rounded border border-[var(--border)] px-1.5 py-0.5 font-mono text-[0.65rem] uppercase tracking-wide text-[var(--text-muted)]">
          {t}
        </span>
      ))
    }
  </div>

  <p class="mt-3 text-[15px] leading-relaxed text-[var(--text)]">{v.phenotype}</p>
  <p class="mt-2 text-sm leading-relaxed text-[var(--text-muted)]">{v.mechanism}</p>

  <dl class="mt-3 flex flex-wrap gap-x-5 gap-y-1 text-xs text-[var(--text-muted)]">
    <div>
      <dt class="inline font-medium text-[var(--text)]">Frequency:</dt>{' '}
      <dd class="inline">{v.frequency}</dd>
    </div>
    {
      v.rsid && (
        <div>
          <dt class="inline font-medium text-[var(--text)]">dbSNP:</dt>{' '}
          <dd class="inline font-mono">{v.rsid}</dd>
        </div>
      )
    }
    {
      v.omim && (
        <div>
          <dt class="inline font-medium text-[var(--text)]">OMIM:</dt>{' '}
          <dd class="inline font-mono">{v.omim}</dd>
        </div>
      )
    }
  </dl>

  <div class="mt-3.5 flex flex-wrap items-center gap-x-4 gap-y-1.5 border-t border-[var(--border)] pt-3 text-xs">
    {
      receptorSlug && (
        <a
          href={`/receptors/${receptorSlug}`}
          class="font-medium text-[var(--accent)] no-underline hover:underline"
        >
          → {v.gene} receptor page
        </a>
      )
    }
    <span class="flex flex-wrap gap-x-3 gap-y-1 text-[var(--text-muted)]">
      {
        v.sources.map((s) => (
          <a
            href={s.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--text-muted)] underline decoration-dotted hover:text-[var(--accent)]"
          >
            {s.authors} {s.year} ↗
          </a>
        ))
      }
    </span>
  </div>
</article>
