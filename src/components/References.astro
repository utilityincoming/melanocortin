---
export interface Reference {
  authors: string;
  title: string;
  source: string;
  year: string;
  url: string;
}
interface Props {
  items: Reference[];
}
const { items } = Astro.props;
---

<section class="mt-14 border-t border-[var(--border)] pt-8">
  <h2 class="font-display text-2xl font-semibold tracking-tight">References</h2>
  <ol class="mt-5 flex flex-col gap-3 text-sm">
    {
      items.map((r, i) => (
        <li id={`ref-${i + 1}`} class="scroll-mt-24 leading-relaxed text-[var(--text-muted)]">
          <span class="mr-1.5 font-mono text-[var(--accent)]">{i + 1}.</span>
          <span class="text-[var(--text)]">{r.authors}</span> {r.title}{' '}
          <span class="italic">{r.source}</span> {r.year}.{' '}
          <a
            href={r.url}
            class="break-words underline decoration-dotted hover:text-[var(--accent)]"
            target="_blank"
            rel="noopener noreferrer"
          >
            link ↗
          </a>
        </li>
      ))
    }
  </ol>
</section>
