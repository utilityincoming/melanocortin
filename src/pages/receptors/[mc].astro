---
import PageLayout from '../../layouts/PageLayout.astro';
import ReceptorFacts from '../../components/ReceptorFacts.astro';
import { receptors } from '../../data/receptors';

export function getStaticPaths() {
  // Receptors with a dedicated full page are served by their own
  // src/pages/receptors/<slug>.astro; only stub the rest here.
  return receptors
    .filter((r) => !r.detailed)
    .map((r) => ({
      params: { mc: r.slug },
      props: { receptor: r },
    }));
}

const { receptor } = Astro.props;
---

<PageLayout
  title={receptor.id}
  kicker="Receptor"
  description={receptor.name}
  status="Stub — full page in development"
>
  <ReceptorFacts receptor={receptor} />

  <p>
    This is a summary card. The full reference page — structure, signalling
    pathway, expression, pharmacology, and cited clinical relevance — is in
    development.
  </p>
  <p>
    <a href="/receptors">← Back to all receptors</a>
  </p>
</PageLayout>
