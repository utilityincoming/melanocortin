---
import BaseLayout from '../layouts/BaseLayout.astro';
import Byline from '../components/Byline.astro';
import FAQ from '../components/FAQ.astro';

// Chart geometry (shared shape with the client script below).
const P = { x0: 48, x1: 704, y0: 16, y1: 324 };
const X = (t: number) => P.x0 + (t / 12) * (P.x1 - P.x0);
const Y = (c: number) => P.y0 + (1 - c / 100) * (P.y1 - P.y0);
const yThresh = Y(55);
const xTicks = [0, 3, 6, 9, 12];
const yTicks = [0, 25, 50, 75, 100];

const routes = [
  { key: 'bolus', label: 'Subcutaneous bolus', swatch: 'var(--accent)' },
  { key: 'oral', label: 'Oral tablet', swatch: 'var(--color-pigment-300)' },
  { key: 'implant', label: 'Controlled-release implant', swatch: 'var(--color-ink-400)' },
];

const faqs = [
  {
    q: 'Why do injections cause more nausea than pills or implants?',
    a: 'Acute melanocortin side effects track the peak blood concentration, not the total dose. A subcutaneous bolus is absorbed fast and spikes to a high peak, which is more likely to cross the threshold for nausea; an oral tablet or a slow-release implant spreads the same drug out, so the peak stays lower.',
  },
  {
    q: 'Does a higher dose mean more side effects?',
    a: 'Largely yes, because a higher dose raises the peak. The same delivery route taken at a higher dose pushes the concentration further above the side-effect threshold and keeps it there longer — which is the logic behind starting low and titrating up.',
  },
  {
    q: 'Why does the afamelanotide implant cause little nausea?',
    a: 'It releases the peptide slowly over weeks, so blood levels rise to a low plateau rather than a sharp peak. Without the concentration spike, the acute side effects that come with bolus injections are largely avoided.',
  },
];
---

<BaseLayout
  title="Dose, delivery & the side-effect peak — an interactive model — melanocortin.com"
  description="An interactive model of why melanocortin injections cause more nausea than pills or implants: it's the concentration peak, not the dose. Compare subcutaneous bolus, oral, and slow-release delivery."
  pageType="article"
  dateModified="2026"
>
  <section class="mx-auto max-w-3xl px-6 py-16">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--accent)]">Interactive</p>
    <h1 class="mt-3 font-serif text-4xl leading-tight font-semibold tracking-tight">
      Dose, delivery & the side-effect peak
    </h1>
    <p class="mt-4 text-lg leading-relaxed text-[var(--text-muted)]">
      Acute melanocortin side effects track the <em>peak</em> concentration, not
      the total dose. Drag the dose and watch how the delivery route decides
      whether the curve crosses into the side-effect zone. Companion to
      <a href="/effects" class="underline decoration-dotted hover:text-[var(--accent)]">why melanocortin agonists make you queasy and tan</a>.
    </p>
    <Byline updated="2026" />

    <!-- Control -->
    <div class="not-prose mt-8 flex items-center gap-4">
      <label for="dose" class="text-sm font-medium">Dose</label>
      <input id="dose" type="range" min="0.5" max="2" step="0.05" value="1" class="dose-range flex-1" />
      <span id="dose-val" class="w-12 text-right font-mono text-sm text-[var(--accent)]">×1.00</span>
    </div>

    <!-- Chart -->
    <div class="not-prose mt-4 rounded-lg border border-[var(--border)] bg-[var(--bg-elevated)] p-4">
      <svg viewBox="0 0 720 360" class="w-full" role="img" aria-label="Plasma concentration over time for three delivery routes, with a side-effect threshold.">
        <!-- side-effect zone -->
        <rect x={P.x0} y={P.y0} width={P.x1 - P.x0} height={yThresh - P.y0} fill="var(--accent)" opacity="0.06" />
        <text x={P.x1 - 6} y={P.y0 + 16} text-anchor="end" font-family="var(--font-mono)" font-size="11" fill="var(--color-pigment-700)">side-effect zone</text>
        <!-- gridlines + y labels -->
        {
          yTicks.map((c) => (
            <g>
              <line x1={P.x0} y1={Y(c)} x2={P.x1} y2={Y(c)} stroke="var(--border)" stroke-width="1" />
              <text x={P.x0 - 8} y={Y(c) + 4} text-anchor="end" font-family="var(--font-mono)" font-size="11" fill="var(--text-muted)">{c}</text>
            </g>
          ))
        }
        <!-- threshold -->
        <line x1={P.x0} y1={yThresh} x2={P.x1} y2={yThresh} stroke="var(--text-muted)" stroke-width="1.5" stroke-dasharray="5 4" />
        <!-- x labels -->
        {
          xTicks.map((t) => (
            <text x={X(t)} y={P.y1 + 22} text-anchor="middle" font-family="var(--font-mono)" font-size="11" fill="var(--text-muted)">{t}h</text>
          ))
        }
        <text x={(P.x0 + P.x1) / 2} y="356" text-anchor="middle" font-family="var(--font-mono)" font-size="11" fill="var(--text-muted)">hours after a dose</text>
        <!-- curves (drawn by script) -->
        <path id="curve-implant" fill="none" stroke="var(--color-ink-400)" stroke-width="2.5" />
        <path id="curve-oral" fill="none" stroke="var(--color-pigment-300)" stroke-width="2.5" />
        <path id="curve-bolus" fill="none" stroke="var(--accent)" stroke-width="3" />
      </svg>
    </div>

    <!-- Legend + readout -->
    <div class="not-prose mt-5 overflow-hidden rounded-lg border border-[var(--border)]">
      <table class="w-full text-left text-sm">
        <thead class="bg-[var(--bg-elevated)] text-xs uppercase tracking-wide text-[var(--text-muted)]">
          <tr>
            <th class="px-4 py-2 font-medium">Delivery route</th>
            <th class="px-4 py-2 font-medium">Peak</th>
            <th class="px-4 py-2 font-medium">Time in zone</th>
            <th class="px-4 py-2 font-medium">Acute load</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[var(--border)]">
          {
            routes.map((r) => (
              <tr>
                <td class="px-4 py-3">
                  <span class="mr-2 inline-block h-2.5 w-2.5 rounded-full align-middle" style={`background:${r.swatch}`} />
                  {r.label}
                </td>
                <td class="px-4 py-3 font-mono" id={`peak-${r.key}`}>—</td>
                <td class="px-4 py-3 font-mono" id={`above-${r.key}`}>—</td>
                <td class="px-4 py-3"><span class="load-badge" id={`load-${r.key}`}>—</span></td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <p class="mt-6 text-sm leading-relaxed text-[var(--text-muted)]">
      This is an <strong class="text-[var(--text)]">illustrative model</strong>, not
      patient data: concentrations are relative and the threshold is a teaching
      device, not a clinical cutoff. The point is the <em>shape</em> — a fast bolus
      peaks high, a pill peaks lower, a slow-release implant barely peaks at all,
      and dose scales it all up or down. It is not medical or dosing advice; see the
      <a href="/about" class="underline decoration-dotted hover:text-[var(--accent)]">editorial standards</a>.
    </p>

    <FAQ items={faqs} />
  </section>
</BaseLayout>

<style>
  .dose-range { accent-color: var(--accent); }
  .load-badge {
    display: inline-block;
    border-radius: 9999px;
    padding: 2px 10px;
    font-size: 12px;
    font-weight: 500;
  }
  .load-low { background: var(--surface, #ecebe7); color: var(--text-muted); }
  .load-mod { background: var(--accent-soft); color: var(--accent-strong); }
  .load-high { background: #f3d9cf; color: #9a3b1e; }
</style>

<script>
  const T = 12, STEPS = 120, THRESH = 55;
  const P = { x0: 48, x1: 704, y0: 16, y1: 324 };
  const X = (t: number) => P.x0 + (t / T) * (P.x1 - P.x0);
  const Y = (c: number) => P.y0 + (1 - Math.min(c, 100) / 100) * (P.y1 - P.y0);

  interface Route { key: string; ka?: number; ke?: number; F?: number; implant?: boolean; target: number; scale?: number; }
  const routes: Route[] = [
    { key: 'bolus', ka: 2.5, ke: 0.35, F: 1, target: 78 },
    { key: 'oral', ka: 0.8, ke: 0.35, F: 0.65, target: 44 },
    { key: 'implant', implant: true, target: 22 },
  ];

  const rawAt = (r: Route, t: number) =>
    r.implant
      ? 1 - Math.exp(-0.5 * t)
      : (r.F! * r.ka!) / (r.ka! - r.ke!) * (Math.exp(-r.ke! * t) - Math.exp(-r.ka! * t));

  // Normalise each route so its dose-1 peak hits the target height.
  for (const r of routes) {
    let m = 0;
    for (let i = 0; i <= STEPS; i++) m = Math.max(m, rawAt(r, (T * i) / STEPS));
    r.scale = r.target / m;
  }
  const concAt = (r: Route, t: number, dose: number) => rawAt(r, t) * r.scale! * dose;

  function pathFor(r: Route, dose: number) {
    let d = '';
    for (let i = 0; i <= STEPS; i++) {
      const t = (T * i) / STEPS;
      d += (i ? 'L' : 'M') + X(t).toFixed(1) + ' ' + Y(concAt(r, t, dose)).toFixed(1) + ' ';
    }
    return d;
  }

  function loadFor(peak: number): [string, string] {
    if (peak < THRESH) return ['Low', 'load-low'];
    if (peak < THRESH * 1.35) return ['Moderate', 'load-mod'];
    return ['High', 'load-high'];
  }

  function update(dose: number) {
    const dv = document.getElementById('dose-val');
    if (dv) dv.textContent = '×' + dose.toFixed(2);
    for (const r of routes) {
      document.getElementById('curve-' + r.key)?.setAttribute('d', pathFor(r, dose));
      let peak = 0, above = 0;
      for (let i = 0; i <= STEPS; i++) {
        const c = concAt(r, (T * i) / STEPS, dose);
        peak = Math.max(peak, c);
        if (c >= THRESH) above += T / STEPS;
      }
      const peakEl = document.getElementById('peak-' + r.key);
      const aboveEl = document.getElementById('above-' + r.key);
      const loadEl = document.getElementById('load-' + r.key);
      if (peakEl) peakEl.textContent = Math.round(peak) + '%';
      if (aboveEl) aboveEl.textContent = above > 0 ? above.toFixed(1) + ' h' : '—';
      if (loadEl) {
        const [lab, cls] = loadFor(peak);
        loadEl.textContent = lab;
        loadEl.className = 'load-badge ' + cls;
      }
    }
  }

  const slider = document.getElementById('dose') as HTMLInputElement | null;
  if (slider) {
    slider.addEventListener('input', () => update(parseFloat(slider.value)));
    update(parseFloat(slider.value));
  }
</script>
