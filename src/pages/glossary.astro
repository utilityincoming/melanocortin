---
import PageLayout from '../layouts/PageLayout.astro';
import { terms } from '../data/glossary';

const slugify = (s: string) =>
  s
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');

// Sort case-insensitively and group by uppercase first letter.
const sorted = [...terms].sort((a, b) =>
  a.term.toLowerCase().localeCompare(b.term.toLowerCase())
);
const groups = new Map<string, typeof terms>();
for (const t of sorted) {
  const letter = t.term[0].toUpperCase();
  if (!groups.has(letter)) groups.set(letter, []);
  groups.get(letter)!.push(t);
}
const letters = [...groups.keys()];
---

<PageLayout
  title="Glossary"
  kicker="Reference"
  description="Plain-language definitions of the melanocortin terms used across the site, cross-linked to the pages that cover them in depth."
  updated="2026"
>
  <nav class="not-prose mt-2 flex flex-wrap gap-1.5" aria-label="Jump to letter">
    {
      letters.map((l) => (
        <a
          href={`#letter-${l}`}
          class="flex h-8 w-8 items-center justify-center rounded-md border border-[var(--border)] font-mono text-sm no-underline transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)]"
        >
          {l}
        </a>
      ))
    }
  </nav>

  <div class="not-prose mt-8 flex flex-col gap-10">
    {
      letters.map((l) => (
        <section>
          <h2
            id={`letter-${l}`}
            class="scroll-mt-24 border-b border-[var(--border)] pb-2 font-serif text-2xl font-semibold tracking-tight text-[var(--accent)]"
          >
            {l}
          </h2>
          <dl class="mt-4 divide-y divide-[var(--border)]">
            {groups.get(l)!.map((t) => (
              <div
                id={slugify(t.term)}
                class="grid scroll-mt-24 grid-cols-1 gap-1 py-4 sm:grid-cols-[12rem_1fr] sm:gap-6"
              >
                <dt class="font-mono text-sm font-semibold">
                  {t.href ? (
                    <a href={t.href} class="text-[var(--accent)] no-underline hover:underline">
                      {t.term}
                    </a>
                  ) : (
                    <span>{t.term}</span>
                  )}
                </dt>
                <dd class="text-sm leading-relaxed text-[var(--text-muted)]">{t.def}</dd>
              </div>
            ))}
          </dl>
        </section>
      ))
    }
  </div>

  <p class="mt-12 text-sm text-[var(--text-muted)]">
    Terms link to the page that covers them in depth. Missing one?
    <a href="/about" class="underline decoration-dotted hover:text-[var(--accent)]">Corrections are welcome.</a>
  </p>
</PageLayout>
