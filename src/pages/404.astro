---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found — melanocortin.com">
  <section class="mx-auto max-w-3xl px-6 py-32 text-center">
    <p class="font-mono text-sm uppercase tracking-[0.2em] text-[var(--accent)]">404</p>
    <h1 class="mt-4 font-serif text-4xl font-semibold tracking-tight">This page hasn't been written yet</h1>
    <p class="mx-auto mt-4 max-w-md leading-relaxed text-[var(--text-muted)]">
      The site is in early development — many pages are still in progress. Try
      one of the main sections instead.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="rounded-md bg-[var(--accent)] px-5 py-2.5 text-sm font-medium text-white no-underline hover:opacity-90">Home</a>
      <a href="/receptors" class="rounded-md border border-[var(--border)] px-5 py-2.5 text-sm font-medium no-underline hover:border-[var(--accent)] hover:text-[var(--accent)]">Receptors</a>
    </div>
  </section>
</BaseLayout>
